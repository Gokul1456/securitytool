NODE_ENV=development

# Database
DATABASE_URL=postgres://sais:sais@localhost:5432/sais

# Auth
JWT_ACCESS_SECRET=please-change-this-to-32+chars-minimum________________
JWT_ISSUER=sais
JWT_AUDIENCE=sais-api

# Inter-service auth
