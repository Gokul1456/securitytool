# ─────────────────────────────────────────────────
#  Login Notifier Service – Environment Variables
# ─────────────────────────────────────────────────

DATABASE_URL=postgres://postgres:password@localhost:5432/login_notifier
PORT=4002
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Internal API key shared across SAIS microservices
SAIS_INTERNAL_API_KEY=internal-secret-123-very-long-key

# ─── Email / SMTP Configuration ───────────────────
# For a real deployment, point to your mail server.
# In demo / dev mode (no SMTP configured), outgoing emails are
# saved to:  C:\combined toolkit\last_email.html  for preview.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=security@sais-demo.com

# ─── Optional: IP risk / VPN detection ────────────
# Get a key from https://ipdata.co or similar provider.
# Leave empty to skip external IP enrichment.
IP_RISK_API_KEY=
