# SAIS API Environment Config
# Copy this file to .env and fill in values as needed

# Port for the SAIS API server (default: 5000)
PORT=5000

# Python executable name/path (Windows often needs "python", Linux/Mac "python3")
PYTHON=python

# CORS origins (comma-separated, or * for open access in dev)
CORS_ORIGIN=*

# Optional: VirusTotal API key (used by malware_scanner.py)
# VT_API_KEY=your_virustotal_api_key_here

# Optional: ClamAV DB path override (Windows)
# CLAMAV_DB=C:\ProgramData\ClamAV\db
